# Copy to ".env" and fill in. Vite exposes only VITE_-prefixed vars to the browser.

# Neon Auth — Console (ep-purple-waterfall) > Auth
VITE_APP_NEON_AUTH_URL=
# Neon Data API — Console > Data API  (…/rest/v1)
VITE_APP_NEON_DATA_API_URL=

# Cloudinary (unsigned upload preset) — reused from the Royal Stay setup
VITE_APP_CLOUDINARY_CLOUD_NAME=da2ts4au6
VITE_APP_CLOUDINARY_UPLOAD_PRESET=royal-stay
